# ─────────────────────────────────────────────
# .gitignore — what Git should NEVER track
# ─────────────────────────────────────────────

# ── Secrets (most important) ─────────────────
.env
.env.*
*.key
*.pem

# ── Python cache ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────
venv/
.venv/
env/
planner/
ENV/

# ── Generated blog outputs ───────────────────
# These are created at runtime — not source code
images/
*.md
!README.md           # keep README if you have one

# ── Streamlit local config ───────────────────
.streamlit/

# ── Docker volumes / local DB ────────────────
redis_data/
data/

# ── Logs ─────────────────────────────────────
*.log
logs/

# ── OS files ─────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── VS Code ──────────────────────────────────
.vscode/
*.code-workspace

# ── PyCharm / JetBrains ──────────────────────
.idea/
*.iml

# ── pytest / coverage ────────────────────────
.pytest_cache/
.coverage
htmlcov/
planner/